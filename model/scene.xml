<mujoco model="dual arms with table and rope scene">
  <include file="dual_iiwa14_2f85/dual_iiwa14_2f85.xml"/>

  <statistic center="0.2 0 0.2" extent="1.0"/>

  <visual>
    <headlight diffuse="0.6 0.6 0.6" ambient="0.3 0.3 0.3" specular="0 0 0"/>
    <rgba haze="0.15 0.25 0.35 1"/>
    <global azimuth="-120" elevation="-20"/>
  </visual>

  <asset>
    <texture type="skybox" builtin="gradient" rgb1="0.3 0.5 0.7" rgb2="0 0 0" width="512" height="3072"/>
    <texture type="2d" name="groundplane" builtin="checker" mark="edge" rgb1="0.2 0.3 0.4" rgb2="0.1 0.2 0.3"
      markrgb="0.8 0.8 0.8" width="300" height="300"/>
    <material name="groundplane" texture="groundplane" texuniform="true" texrepeat="5 5" reflectance="0.2"/>
  </asset>
  <extension>
   <plugin plugin="mujoco.elasticity.cable"/>
</extension>
  <worldbody>
    <composite prefix="actuated" type="cable" curve="0 s 0" count="41 1 1"
                size="0.5 0.1 4" offset="0 -0.25 1.445" initial="free">
        <joint kind="main" stiffness="0.02" damping="0.03"/>
        <geom type="capsule" size=".005" rgba=".8 .2 .1 1"/>
        <site size="0.005" rgba="0 1 0 1"/>
    </composite>
    <light pos="0 0 1.5" dir="0 0 -1" directional="true"/>
    <geom name="floor" size="0 0 0.05" type="plane" material="groundplane"/>

    <!-- Table -->
    <body name="table" pos="0.7 0 0" axisangle="0 0 1 1.57">
      <!-- tabletop: size = half-lengths -->
      <geom name="table_top" type="box" size="0.4 0.3 0.025" pos="0 0 0.75"
            rgba="0.55 0.35 0.2 1"/>

      <!-- legs -->
      <geom name="leg1" type="box" size="0.025 0.025 0.375" pos=" 0.35  0.25 0.375" rgba="0.3 0.2 0.1 1"/>
      <geom name="leg2" type="box" size="0.025 0.025 0.375" pos="-0.35  0.25 0.375" rgba="0.3 0.2 0.1 1"/>
      <geom name="leg3" type="box" size="0.025 0.025 0.375" pos=" 0.35 -0.25 0.375" rgba="0.3 0.2 0.1 1"/>
      <geom name="leg4" type="box" size="0.025 0.025 0.375" pos="-0.35 -0.25 0.375" rgba="0.3 0.2 0.1 1"/>
    </body>

    <!-- Obstacles -->
    <geom name="floating_sphere_1" type="sphere" size="0.0635" pos="0.62 -0.07 0.9" rgba="0.74 0.90 1.00 1"/>
    <geom name="floating_rect_prism_1" type="box" size="0.0635 0.0400 0.03175" pos="0.56 0.16 0.85" rgba="0.80 0.93 1.00 1"/>
    <geom name="floating_rect_prism_2" type="box" size="0.0635 0.0635 0.0635" pos="0.85 0.16 0.925" euler="15 30 10" rgba="0.80 0.93 1.00 1"/>
    <geom name="floating_sphere_2" type="sphere" size="0.0580" pos="0.78 -0.22 0.95" rgba="0.40 0.83 0.97 1"/>

    
  </worldbody>
  <equality>
    <weld name="left_anchor" site1="iiwa14_1/pinch_site" site2="actuatedS_first" solimp="0.9 0.95 0.001" solref="0.005 1"/>
    <weld name="right_anchor" site1="iiwa14/pinch_site" site2="actuatedS_last" solimp="0.9 0.95 0.001" solref="0.005 1"/>
  </equality>
</mujoco>
